    { "key": "demo-the-couple-exit",      "nameKey": "moment.the-couple-exit.name",      "shortNameKey": "moment.the-couple-exit.short",      "colourKey": "orange", "segment": "daytime", "autoAdvanceToNext": false, "sortOrder": 2 }
