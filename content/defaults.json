  "demoMoments": [
    { "key": "demo-walking-the-aisle",    "nameKey": "moment.walking-the-aisle.name",    "shortNameKey": "moment.walking-the-aisle.short",    "colourKey": "blue",   "segment": "daytime", "autoAdvanceToNext": true,  "sortOrder": 0 },
