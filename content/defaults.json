{
  "schemaVersion": 1,

  "cdnBaseURL": "https://cdn.weddingplayer.app/music",

  "iap": {
    "fullAccessProductId": "com.donmcallister.weddingplayer.fullaccess"
  },

  "playback": {
    "fadeDurationSecs": 5.0,
    "crossfadeSecs": 3.0,
    "autoAdvance": true
  },

  "segments": [
    { "key": "daytime", "displayKey": "segment.daytime" },
    { "key": "evening", "displayKey": "segment.evening" }
  ],

  "colours": [
