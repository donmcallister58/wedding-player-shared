    { "key": "green",  "displayKey": "colour.sage",      "lightHex": "#6B9E70", "darkHex": "#88B88D", "tabLightHex": "#58835C", "tabDarkHex": "#709A74" },
    { "key": "orange", "displayKey": "colour.amber",     "lightHex": "#C49A45", "darkHex": "#D4B462", "tabLightHex": "#A47F38", "tabDarkHex": "#B09850" },
    { "key": "purple", "displayKey": "colour.mauve",     "lightHex": "#8B6EA0", "darkHex": "#A88AB8", "tabLightHex": "#735A85", "tabDarkHex": "#8C7298" },
    { "key": "red",    "displayKey": "colour.burgundy",  "lightHex": "#8B5A5A", "darkHex": "#A87474", "tabLightHex": "#734A4A", "tabDarkHex": "#8C6060" },
    { "key": "teal",   "displayKey": "colour.teal",      "lightHex": "#5E9E9E", "darkHex": "#7AB8B8", "tabLightHex": "#4D8383", "tabDarkHex": "#649A9A" },
    { "key": "indigo", "displayKey": "colour.steel",     "lightHex": "#6482A0", "darkHex": "#849CBA", "tabLightHex": "#526B85", "tabDarkHex": "#6C829C" },
    { "key": "pink",   "displayKey": "colour.rose",      "lightHex": "#C47A80", "darkHex": "#D4949A", "tabLightHex": "#A4656A", "tabDarkHex": "#B07A80" },
    { "key": "mint",   "displayKey": "colour.seafoam",   "lightHex": "#7BAAAA", "darkHex": "#95C4C4", "tabLightHex": "#658D8D", "tabDarkHex": "#7CA4A4" },
    { "key": "brown",  "displayKey": "colour.taupe",     "lightHex": "#8A7A62", "darkHex": "#A8967C", "tabLightHex": "#726550", "tabDarkHex": "#8C7C66" },
    { "key": "cyan",   "displayKey": "colour.coral",     "lightHex": "#D4968A", "darkHex": "#E0B0A4", "tabLightHex": "#B07C72", "tabDarkHex": "#BA9288" },
    { "key": "yellow", "displayKey": "colour.honey",     "lightHex": "#B8A060", "darkHex": "#D0BA78", "tabLightHex": "#9A854F", "tabDarkHex": "#AC9C62" }
