  "colourAutoSequence": ["teal", "pink", "indigo", "orange", "mint", "purple", "cyan", "brown", "blue", "yellow", "green", "red"],

  "defaultMoments": [
    { "key": "guests-arriving",      "nameKey": "moment.guests-arriving.name",      "shortNameKey": "moment.guests-arriving.short",      "colourKey": "teal",   "segment": "daytime", "autoAdvanceToNext": false, "sortOrder": 0 },
    { "key": "walking-the-aisle",    "nameKey": "moment.walking-the-aisle.name",    "shortNameKey": "moment.walking-the-aisle.short",    "colourKey": "blue",   "segment": "daytime", "autoAdvanceToNext": true,  "sortOrder": 1 },
    { "key": "signing-the-register", "nameKey": "moment.signing-the-register.name", "shortNameKey": "moment.signing-the-register.short", "colourKey": "green",  "segment": "daytime", "autoAdvanceToNext": true,  "sortOrder": 2 },
    { "key": "the-couple-exit",      "nameKey": "moment.the-couple-exit.name",      "shortNameKey": "moment.the-couple-exit.short",      "colourKey": "orange", "segment": "daytime", "autoAdvanceToNext": false, "sortOrder": 3 },
    { "key": "wedding-breakfast",    "nameKey": "moment.wedding-breakfast.name",    "shortNameKey": "moment.wedding-breakfast.short",    "colourKey": "purple", "segment": "daytime", "autoAdvanceToNext": false, "sortOrder": 4 },
    { "key": "drinks-reception",     "nameKey": "moment.drinks-reception.name",     "shortNameKey": "moment.drinks-reception.short",     "colourKey": "mint",   "segment": "evening", "autoAdvanceToNext": false, "sortOrder": 5 }
